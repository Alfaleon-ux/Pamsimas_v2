# ===========================================
# Pamsimas — Environment Variables
# ===========================================

# Supabase PostgreSQL Connection (Transaction Pooler)
# Found in: Supabase Dashboard → Settings → Database → Connection string → URI
# Use port 6543 for Transaction pooler mode (required for serverless)
DATABASE_URL=postgresql://postgres.[your-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=https://your-app.vercel.app

# Supabase Storage (for meter photos)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=meter-photos

# CORS Origins (comma-separated, your Vercel domain)
CORS_ORIGIN=https://your-app.vercel.app

# Server (local dev only, not used on Vercel)
PORT=3000
